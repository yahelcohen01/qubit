{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["development"],
    "paths": {
      "@ui": ["./libs/ui/src/index.ts"],
      "@ui/*": ["./libs/ui/src/*"],
      "@utils": ["./libs/utils/src/index.ts"],
      "@utils/*": ["./libs/utils/src/*"],
      "@types": ["./libs/types/src/index.ts"],
      "@types/*": ["./libs/types/src/*"]
    }
  }
}
